# Kimi API 配置
# ==========================================
# 方案一：使用 Moonshot 开放平台 API（推荐）
# 从 https://platform.moonshot.cn/ 获取 API Key
# KIMI_API_KEY=你的moonshot_api_key
# KIMI_API_URL=https://api.moonshot.cn/v1/chat/completions
# KIMI_MODEL=kimi-k2.5

# ==========================================
# 方案二：使用 Kimi Code API（如果你有会员）
# 从 https://www.kimi.com/code/console 获取 Kimi Code API Key
# 注意：Kimi Code 主要用于代码助手，不确定是否支持通用对话
KIMI_API_KEY=your_kimi_code_api_key_here
KIMI_API_URL=https://api.kimi.com/v1/chat/completions
KIMI_MODEL=kimi-for-coding

# ==========================================
# 可用的模型名称参考
# Moonshot 普通模型: moonshot-v1-8k, moonshot-v1-32k, moonshot-v1-128k
# Moonshot 最新模型: kimi-k2.5, kimi-k2.5-8k, kimi-k2.5-32k, kimi-k2.5-128k
# Kimi Code 模型: kimi-for-coding
KIMI_MODEL=kimi-k2.5